if(NOT DEFINED LOCALE_DIR)
  message(FATAL_ERROR "LOCALE_DIR is required")
endif()

set(reference_file "${LOCALE_DIR}/en-US.ini")
if(NOT EXISTS "${reference_file}")
  message(FATAL_ERROR "Reference locale not found: ${reference_file}")
endif()

function(read_locale_keys file output_var)
  file(STRINGS "${file}" lines ENCODING UTF-8)
  set(keys)
  foreach(line IN LISTS lines)
    if(line MATCHES "^([^#=]+)=")
      string(STRIP "${CMAKE_MATCH_1}" key)
      list(APPEND keys "${key}")
    endif()
  endforeach()
  list(REMOVE_DUPLICATES keys)
  set(${output_var} ${keys} PARENT_SCOPE)
endfunction()

read_locale_keys("${reference_file}" reference_keys)
file(GLOB locale_files "${LOCALE_DIR}/*.ini")

set(errors)
foreach(locale_file IN LISTS locale_files)
  get_filename_component(locale_name "${locale_file}" NAME)
  read_locale_keys("${locale_file}" locale_keys)

  set(missing)
  foreach(key IN LISTS reference_keys)
    if(NOT key IN_LIST locale_keys)
      list(APPEND missing "${key}")
    endif()
  endforeach()

  set(extra)
  foreach(key IN LISTS locale_keys)
    if(NOT key IN_LIST reference_keys)
      list(APPEND extra "${key}")
    endif()
  endforeach()

  if(missing OR extra)
    string(REPLACE ";" ", " missing_text "${missing}")
    string(REPLACE ";" ", " extra_text "${extra}")
    list(APPEND errors "${locale_name}: missing=[${missing_text}] extra=[${extra_text}]")
  endif()
endforeach()

if(errors)
  string(REPLACE ";" "\n" error_text "${errors}")
  message(FATAL_ERROR "Locale key parity failed:\n${error_text}")
endif()

message(STATUS "Locale key parity passed")
